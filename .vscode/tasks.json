{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile Java",
            "type": "shell",
            "command": "javac",
            "args": [
                "${file}"
            ],
            "group": "build",
            "problemMatcher": [
                "$javac"
            ]
        },
        {
            "label": "Run Java",
            "type": "shell",
            "command": "cd ${workspaceFolder}/src && javac ${relativeFile#src/} && java $(echo '${relativeFile#src/}' | sed 's/.java$//' | tr '/' '.')",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "focus": true,
                "reveal": "always"
            },
            "problemMatcher": []
        }
    ]
}